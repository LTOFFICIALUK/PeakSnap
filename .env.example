# Neon Postgres (pooled — used by the app at runtime)
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# Neon Postgres (direct — used by Prisma migrations only)
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require"

# Shared secret for POST /api/admin/build-deck (generate: openssl rand -hex 32)
ADMIN_SECRET="replace-with-openssl-rand-hex-32"

# Optional — extra 1m OHLCV when GeckoTerminal is rate-limited
BIRDEYE_API_KEY=""

# Set to "true" on Vercel (auto-set via VERCEL=1). On your PC leave unset so deck:live works.
# SKIP_LIVE_BUILD="true"
