generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Deck {
  id        String     @id @default(cuid())
  deckDate  String     @unique
  createdAt DateTime   @default(now())
  cards     Card[]
  dailyRuns DailyRun[]
}

model Card {
  id              String   @id @default(cuid())
  deckId          String
  deck            Deck     @relation(fields: [deckId], references: [id], onDelete: Cascade)
  sortOrder       Int
  tokenMint       String
  tokenSymbol     String
  tokenName       String?
  tokenImage      String?
  poolAddress     String?
  freezeTimestamp Int
  patternTag      String
  peakGainPct     Float
  dropAfterPct    Float
  gainAfterPct    Float    @default(0)
  correctChoice   String   @default("EXIT")
  candlesJson     String
  createdAt       DateTime @default(now())
  guesses         Guess[]

  @@index([deckId, sortOrder])
}

model Guess {
  id        String   @id @default(cuid())
  cardId    String
  card      Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  sessionId String
  choice    String
  correct   Boolean
  createdAt DateTime @default(now())

  @@index([sessionId])
  @@index([cardId, sessionId])
}

model DailyRun {
  id          String   @id @default(cuid())
  deckId      String
  deck        Deck     @relation(fields: [deckId], references: [id], onDelete: Cascade)
  deckDate    String
  sessionId   String
  displayName String   @default("Anon")
  correct     Int
  total       Int
  completedAt DateTime @default(now())

  @@unique([deckId, sessionId])
  @@index([deckDate, correct])
  @@index([sessionId])
}
